<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>花卉資源管理系統</title>
    <style>
        :root { --primary: #2e7d32; --blue: #2196f3; --bg: #f8f9fa; --white-node: #9e9e9e; --yellow-node: #f9a825; --red-node: #e53935; --blue-node: #1565c0; }
        body { font-family: -apple-system, "Noto Sans TC", sans-serif; background-color: var(--bg); padding: 15px; margin: 0; }
        .container { max-width: 1300px; margin: 0 auto; background: white; padding: 20px; border-radius: 15px; box-shadow: 0 5px 25px rgba(0,0,0,0.1); }
        
        /* AI 辨識區 */
        .ai-zone { background: #eef2f7; border: 1px solid #d1d9e6; padding: 15px; border-radius: 12px; margin-bottom: 20px; }
        .instruction-box { background: #fff; border-left: 5px solid #ff9800; padding: 12px; margin-bottom: 15px; display: flex; justify-content: space-between; align-items: center; border-radius: 4px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); }
        .instruction-text { font-size: 0.9rem; color: #333; line-height: 1.5; }
        
        .import-controls { display: flex; flex-direction: column; gap: 10px; }
        textarea { width: 100%; height: 100px; padding: 12px; border: 1px solid #ccc; border-radius: 6px; font-family: monospace; font-size: 13px; box-sizing: border-box; }
        .button-group { display: flex; gap: 10px; flex-wrap: wrap; }
        
        /* 儀表板 */
        .dashboard { background: white; border: 1px solid #eee; padding: 15px; border-radius: 12px; margin-bottom: 20px; }
        .main-stats { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 15px; border-bottom: 1px dashed #ddd; padding-bottom: 15px; }
        .progress-bar-bg { width: 60%; max-width: 400px; background: #eee; height: 14px; border-radius: 7px; overflow: hidden; }
        .progress-bar-fill { height: 100%; background: linear-gradient(90deg, #4caf50, #a2d149); width: 0%; transition: width 0.6s ease; }
        
        .color-stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 10px; }
        .color-stat-card { padding: 8px; border-radius: 8px; text-align: center; border: 1px solid #eee; background: #fff; }
        .cs-white { border-left: 5px solid var(--white-node); }
        .cs-yellow { border-left: 5px solid var(--yellow-node); }
        .cs-red { border-left: 5px solid var(--red-node); }
        .cs-blue { border-left: 5px solid var(--blue-node); }
        .cs-val { font-size: 1.1rem; font-weight: bold; margin-top: 5px; }
        .cs-label { font-size: 0.75rem; color: #666; }

        /* 表格樣式 */
        .table-wrapper { overflow-x: auto; max-height: 500px; border: 1px solid #eee; border-radius: 8px; }
        table { width: 100%; border-collapse: collapse; min-width: 1100px; }
        th, td { border: 1px solid #dee2e6; text-align: center; padding: 6px 4px; }
        th { background: #f1f3f5; position: sticky; top: 0; z-index: 10; font-size: 0.85rem; }
        .th-color { color: white; padding: 8px; }
        .name-td { font-weight: bold; background: #fafafa; width: 120px; position: sticky; left: 0; z-index: 5; border-right: 2px solid #eee; }
        
        input[type="number"] { width: 85%; border: 1px solid transparent; background: rgba(0,0,0,0.03); text-align: center; font-size: 1rem; padding: 4px; border-radius: 4px; }
        input[type="number"]:focus { background: #fff; border: 1px solid var(--blue); outline: none; }
        .owned-cell { background-color: #e8f5e9 !important; }
        
        .btn { border: none; padding: 10px 18px; border-radius: 6px; cursor: pointer; font-weight: bold; transition: 0.3s; flex: 1; min-width: 120px; text-align: center; }
        .btn-copy { background: #ff9800; color: white; }
        .btn-import { background: var(--blue); color: white; }
        .btn-paste { background: #673ab7; color: white; }
        .btn-clear { background: #f44336; color: white; }
        .btn-reset { background: #90a4ae; color: white; font-size: 12px; }
        
        .missing-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px; }
        .tag { background: white; border: 1px solid #ffb3b3; color: #d32f2f; padding: 2px 10px; border-radius: 15px; font-size: 11px; }
    </style>
</head>
<body>

<div class="container">
    <header style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
        <h3 style="margin:0; color: #2e7d32;">🌸 花卉資源管理系統</h3>
        <button class="btn btn-reset" style="flex:none; min-width:auto;" onclick="resetData()">重設資料</button>
    </header>

    <div class="ai-zone">
        <div class="instruction-box">
            <span class="instruction-text" id="prompt-text">請幫我讀取這張圖，並輸出 JSON 代碼。規範：1. 格式為 `[{"n":"花名","c":"白/黃/紅/藍","f":精華數,"e":花瓣數}]`。 2. <b>花名(n) 必須移除前面的顏色字眼</b>。 3. 顏色(c) 只能用單字：白、黃、紅、藍。 4. 請只輸出 JSON，不要解釋。</span>
            <button class="btn btn-copy" style="flex:none; min-width:auto;" onclick="copyPrompt()">複製指令</button>
        </div>
        <div class="import-controls">
            <textarea id="import-json" placeholder='在此貼入 AI 回傳的 JSON 代碼...'></textarea>
            <div class="button-group">
                <button class="btn btn-import" onclick="importData()">導入更新並計算進度</button>
                <button class="btn btn-paste" onclick="pasteFromClipboard()">一鍵貼上</button>
                <button class="btn btn-clear" onclick="clearTextarea()">清除內容</button>
            </div>
        </div>
    </div>

    <div class="dashboard">
        <div class="main-stats">
            <div>
                <div style="font-size: 0.85rem; color: #666;">總收集率</div>
                <div style="font-size: 2rem; font-weight: bold; color: var(--primary);" id="stat-percent">0%</div>
                <div id="stat-count" style="font-size: 0.8rem; color: #888;">0 / 0</div>
            </div>
            <div class="progress-bar-bg"><div id="progress-bar" class="progress-bar-fill"></div></div>
        </div>
        
        <div class="color-stats-grid">
            <div class="color-stat-card cs-white"><div class="cs-label">白色完成</div><div class="cs-val" id="cs-val-白" style="color:var(--white-node)">0%</div></div>
            <div class="color-stat-card cs-yellow"><div class="cs-label">黃色完成</div><div class="cs-val" id="cs-val-黃" style="color:var(--yellow-node)">0%</div></div>
            <div class="color-stat-card cs-red"><div class="cs-label">紅色完成</div><div class="cs-val" id="cs-val-紅" style="color:var(--red-node)">0%</div></div>
            <div class="color-stat-card cs-blue"><div class="cs-label">藍色完成</div><div class="cs-val" id="cs-val-藍" style="color:var(--blue-node)">0%</div></div>
        </div>
    </div>

    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th rowspan="2" style="width: 120px;">花卉名稱</th>
                    <th colspan="3" class="th-color" style="background:var(--white-node)">白色</th>
                    <th colspan="3" class="th-color" style="background:var(--yellow-node)">黃色</th>
                    <th colspan="3" class="th-color" style="background:var(--red-node)">紅色</th>
                    <th colspan="3" class="th-color" style="background:var(--blue-node)">藍色</th>
                </tr>
                <tr style="font-size: 11px; background: #f8f9fa;">
                    <th>有</th><th>精華</th><th>花瓣</th>
                    <th>有</th><th>精華</th><th>花瓣</th>
                    <th>有</th><th>精華</th><th>花瓣</th>
                    <th>有</th><th>精華</th><th>花瓣</th>
                </tr>
            </thead>
            <tbody id="table-body"></tbody>
        </table>
    </div>

    <div style="margin-top: 15px; padding: 12px; background: #fff5f5; border-radius: 10px; border: 1px solid #ffdada;">
        <div style="font-size: 0.9rem; font-weight: bold; color: #d32f2f;">📌 尚未擁有的項目：</div>
        <div id="missing-tags" class="missing-tags"></div>
    </div>
</div>

<script>
const flowers = [
    {n:"三色堇", c:["白","黃","紅","藍"]}, {n:"玫瑰", c:["白","黃","紅","藍"]}, {n:"聖誕紅", c:["白","黃","紅","藍"]},
    {n:"山茶花", c:["白","黃","紅","藍"]}, {n:"梅花", c:["白","黃","紅"]}, {n:"櫻花", c:["白"]},
    {n:"鬱金香", c:["白","黃","紅","藍"]}, {n:"繡球花", c:["白","紅","藍"]}, {n:"百合", c:["白","黃","紅"]},
    {n:"向日葵", c:["黃"]}, {n:"彼岸花", c:["白","黃","紅"]}, {n:"大波斯菊", c:["白","黃","紅"]},
    {n:"兔耳花", c:["白","紅","藍"]}, {n:"水仙花", c:["白","黃"]}, {n:"銀蓮花", c:["白","黃","紅","藍"]},
    {n:"粉蝶花", c:["藍"]}, {n:"康乃馨", c:["白","黃","紅","藍"]}, {n:"海芋", c:["白","黃","紅","藍"]},
    {n:"雞蛋花", c:["白","黃","紅"]}, {n:"扶桑花", c:["白","黃","紅","藍"]}, {n:"石竹", c:["白","紅","藍"]},
    {n:"龍膽", c:["白","紅","藍"]}, {n:"菊花", c:["白","黃","紅","藍"]}, {n:"聖誕玫瑰", c:["白","黃","紅","藍"]},
    {n:"嘉德麗雅蘭", c:["白","黃","紅","藍"]}, {n:"風信子", c:["白","黃","紅","藍"]}, {n:"豌豆花", c:["白","黃","紅","藍"]},
    {n:"鈴蘭", c:["白","紅"]}, {n:"牡丹", c:["白","黃","紅","藍"]}, {n:"睡蓮", c:["白","黃","紅","藍"]},
    {n:"牽牛花", c:["白","黃","紅","藍"]}, {n:"九重葛", c:["白","黃","紅","藍"]}, {n:"大理花", c:["白","黃","紅","藍"]},
    {n:"鐵線蓮", c:["白","黃","紅","藍"]}, {n:"雪花蓮", c:["白","黃","紅"]}, {n:"小蒼蘭", c:["白","黃","紅","藍"]},
    {n:"油菜花", c:["白","黃","藍"]}, {n:"週年紀念玫瑰", c:["白","黃","紅","藍"]}, {n:"鳶尾花", c:["白","黃","紅","藍"]},
    {n:"天堂鳥", c:["白","黃","紅"]}, {n:"雞冠花", c:["白","黃","紅","藍"]}, {n:"萬壽菊", c:["白","黃","紅"]},
    {n:"鼠尾草", c:["白","黃","紅","藍"]}, {n:"櫻草花", c:["白","黃","紅","藍"]}, {n:"金魚草", c:["白","黃","紅","藍"]},
    {n:"矮牽牛", c:["白","紅","黃","藍"]}, {n:"精華", c:["白","黃","紅","藍"]}
];

const colorKeys = ["白", "黃", "紅", "藍"];

function renderTable() {
    const tbody = document.getElementById('table-body');
    tbody.innerHTML = flowers.map(f => {
        const cells = colorKeys.map(color => {
            if (!f.c.includes(color)) return `<td colspan="3" style="background:#f5f5f5; opacity:0.3"></td>`;
            const id = `${f.n}-${color}`;
            const d = JSON.parse(localStorage.getItem(id)) || {owned: false, f: '', e: ''};
            const cls = d.owned ? 'owned-cell' : '';
            return `
                <td class="${cls}" id="cell-check-${id}"><input type="checkbox" onchange="updateData('${id}','owned',this.checked)" ${d.owned ? 'checked' : ''}></td>
                <td class="${cls}" id="cell-f-${id}"><input type="number" value="${d.f}" oninput="updateData('${id}','f',this.value)" placeholder="0"></td>
                <td class="${cls}" id="cell-e-${id}"><input type="number" value="${d.e}" oninput="updateData('${id}','e',this.value)" placeholder="0"></td>
            `;
        }).join('');
        return `<tr><td class="name-td">${f.n}</td>${cells}</tr>`;
    }).join('');
    calculateStats();
}

function updateData(id, field, value) {
    let d = JSON.parse(localStorage.getItem(id)) || {owned: false, f: '', e: ''};
    d[field] = value;
    localStorage.setItem(id, JSON.stringify(d));
    if (field === 'owned') {
        ['cell-check-', 'cell-f-', 'cell-e-'].forEach(pre => {
            const el = document.getElementById(pre + id);
            if (el) el.classList.toggle('owned-cell', value);
        });
    }
    calculateStats();
}

function calculateStats() {
    let totalAll = 0, ownedAll = 0, missingHtml = '';
    const colorStats = { "白": {t:0, o:0}, "黃": {t:0, o:0}, "紅": {t:0, o:0}, "藍": {t:0, o:0} };
    flowers.forEach(f => {
        colorKeys.forEach(color => {
            if (f.c.includes(color)) {
                totalAll++; colorStats[color].t++;
                const d = JSON.parse(localStorage.getItem(`${f.n}-${color}`)) || {owned: false};
                if (d.owned) { ownedAll++; colorStats[color].o++; }
                else { missingHtml += `<span class="tag">${f.n}(${color})</span>`; }
            }
        });
    });
    const pctAll = totalAll > 0 ? Math.round((ownedAll / totalAll) * 100) : 0;
    document.getElementById('stat-count').innerText = `${ownedAll} / ${totalAll}`;
    document.getElementById('stat-percent').innerText = pctAll + '%';
    document.getElementById('progress-bar').style.width = pctAll + '%';
    colorKeys.forEach(c => {
        const pct = colorStats[c].t > 0 ? Math.round((colorStats[c].o / colorStats[c].t) * 100) : 0;
        document.getElementById(`cs-val-${c}`).innerText = `${pct}% (${colorStats[c].o}/${colorStats[c].t})`;
    });
    document.getElementById('missing-tags').innerHTML = missingHtml || '🌟 全收集達成！';
}

function clearTextarea() { document.getElementById('import-json').value = ''; }

async function pasteFromClipboard() {
    try {
        const text = await navigator.clipboard.readText();
        document.getElementById('import-json').value = text;
    } catch (err) { alert('無法自動讀取剪貼簿，請手動貼入。'); }
}

function importData() {
    const raw = document.getElementById('import-json').value.trim();
    if (!raw) return;
    try {
        const data = JSON.parse(raw);
        data.forEach(item => {
            let shortColor = item.c.charAt(0);
            let pureName = item.n.trim();
            const colorPrefixes = ["紅色", "白色", "黃色", "藍色", "紅", "白", "黃", "藍"];
            colorPrefixes.forEach(p => { if(pureName.startsWith(p)) pureName = pureName.replace(p, ""); });
            
            if (pureName === "三色菫" || pureName === "三色堇菫") pureName = "三色堇";
            if (pureName === "碗豆花") pureName = "豌豆花";
            if (pureName === "水仙") pureName = "水仙花";

            const id = `${pureName.trim()}-${shortColor}`;
            let d = JSON.parse(localStorage.getItem(id)) || {owned: false, f: '', e: ''};
            d.owned = true;
            if(item.f !== undefined) d.f = item.f;
            if(item.e !== undefined) d.e = item.e;
            localStorage.setItem(id, JSON.stringify(d));
        });
        renderTable();
        alert('導入成功！名詞已自動對應至「精華」與「花瓣」。');
    } catch (e) { alert('JSON 格式錯誤。'); }
}

function copyPrompt() {
    navigator.clipboard.writeText(document.getElementById('prompt-text').innerText).then(() => alert('指令已複製！'));
}

function resetData() { if(confirm('確定清空所有進度嗎？')) { localStorage.clear(); renderTable(); } }

renderTable();
</script>
</body>
</html>
